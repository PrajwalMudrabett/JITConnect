# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection String
# Replace with your actual MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/jitconnect?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jitconnect?retryWrites=true&w=majority

# JWT Secret Key
# Generate a random secret key for production
JWT_SECRET=jitconnect_secret_key_change_this_in_production_2024

# Instructions:
# 1. Copy this file to .env
# 2. Replace MONGODB_URI with your actual MongoDB Atlas connection string
# 3. Replace JWT_SECRET with a random secure string
# 4. Never commit .env file to Git
